## Ignore Visual Studio temporary files, build results, and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/xamarin)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Log]s/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create to-do list files
#*.tasks

# MSTest test Results
[T]est[R]esult*/
[B]uild[L]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-confort.log

# DNX
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

